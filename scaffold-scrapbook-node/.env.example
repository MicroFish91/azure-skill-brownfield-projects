# Couples Scrapbook - Environment Variables

# Essential Services
DATABASE_URL=postgresql://localdev:localdevpassword@localhost:5432/scrapbookdb
STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
JWT_SECRET=your-local-dev-jwt-secret-change-in-production

# Enhancement Services (optional - app works without these)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# App Config
NODE_ENV=development
